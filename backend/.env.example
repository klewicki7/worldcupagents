# Settings.model_config uses extra="ignore", so future phases can add keys here
# (Sentry DSN, FOOTBALL_DATA_TOKEN, etc.) before the code reads them.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/worldcupagents  # asyncpg-style DSN
JWT_SECRET=change-me-in-production  # MUST equal worldcupagents-fe/NEXTAUTH_SECRET
JWT_ALGORITHM=HS256  # HMAC-SHA256
ENVIRONMENT=development  # development | production
LOG_LEVEL=info  # debug | info | warning | error
GOOGLE_OAUTH_CLIENT_ID=  # Web client ID issued by Google Cloud Console
ADMIN_EMAILS=  # comma-separated; matching humans get is_admin=true on signup
PUBLIC_BASE_URL=http://localhost:3000  # frontend origin (for CORS / config snippets)
MCP_BASE_URL=http://localhost:8000  # base for the MCP HTTP endpoint
