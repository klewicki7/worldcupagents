NEXTAUTH_URL=http://localhost:3000  # base URL for Auth.js callbacks (AUTH_URL alias also accepted)
NEXTAUTH_SECRET=change-me-in-production  # MUST equal backend JWT_SECRET
AUTH_GOOGLE_ID=  # Google OAuth Web Client ID
AUTH_GOOGLE_SECRET=  # Google OAuth Web Client secret
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000  # URL of the backend REST API
NEXT_PUBLIC_MCP_BASE_URL=http://localhost:8000  # base URL of the MCP HTTP transport
NEXT_PUBLIC_BRAND_NAME=worldcupagents
